# Copy to `.env.e2e.local` (gitignored) and fill values. Then:
#   set -a && source .env.e2e.local && set +a && ./scripts/run_local_optional_e2e.sh
#
# Local TradeTalk API (uvicorn on :8000)
E2E_API_BASE_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173
APP_URL=http://localhost:5173

# FaultHunter API smoke (subset)
# FH_PROFILE=smoke

# FinCrawler (optional HTTP E2E)
FINCRAWLER_URL=http://34.41.127.205:10000
# FINCRAWLER_KEY=required-for-/quote-test-if-server-enforces-auth
# FINCRAWLER_POLYMARKET_E2E=1

# LLM production QA — OpenAI-compatible (NVIDIA Build example)
# Use your NVIDIA Build API key in OPENAI_API_KEY, or set NVIDIA_API_KEY instead.
LLM_QA_USE_NVIDIA=1
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_QA_MODEL=deepseek-ai/deepseek-v4-flash
# LLM_QA_NO_RESPONSE_FORMAT=0

# OPENAI_API_KEY=
# NVIDIA_API_KEY=

# Provider smoke — hits /health/smoke/* on API (requires ALLOW_PROVIDER_SMOKE=1 on server).
# ALLOW_PROVIDER_SMOKE=1
# PROVIDER_SMOKE_SECRET=optional-shared-secret
# E2E_PROVIDER_SMOKE_SECRET=optional-shared-secret
