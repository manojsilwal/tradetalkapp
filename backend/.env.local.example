# Copy to backend/.env.local (gitignored). Loaded after backend/.env with override=True.
#
# Spot price when yfinance / Yahoo fail (fetch_us_equity_spot):
#   Stooq → (optional) Yahoo chart if QUOTE_FALLBACK_ALLOW_YAHOO_CHART=1 → FinCrawler last
#
# Start FinCrawler locally (separate repo):
#   cd /path/to/fincrawler && export API_KEY=your-secret && uvicorn main:app --host 127.0.0.1 --port 10000
#
FINCRAWLER_URL=http://127.0.0.1:10000
FINCRAWLER_KEY=your-fincrawler-api-key
FINCRAWLER_QUOTE_TIMEOUT_S=8

# Default: do not call Yahoo chart again after yfinance already failed
# QUOTE_FALLBACK_ALLOW_YAHOO_CHART=0
