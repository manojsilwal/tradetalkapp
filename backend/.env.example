# Required for live TradeTalk chat (streaming). Without it, chat returns a fixed notice — see backend/llm_client.py stream_chat_plain.
# Get a key at https://openrouter.ai — copy backend/.env.example to backend/.env and set the value.
OPENROUTER_API_KEY=
# Optional second OpenRouter account — requests round-robin between keys for higher daily quota.
OPENROUTER_API_KEY_2=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter model IDs use vendor slugs with no extra hyphen (e.g. qwen3.6 not qwen-3.6).
OPENROUTER_MODEL=qwen/qwen3.6-plus:free
# Lighter model for non-reasoning roles (defaults to OPENROUTER_MODEL if unset).
# Set to a cheaper/faster model when available to reduce cost.
OPENROUTER_MODEL_LIGHT=qwen/qwen3.6-plus:free
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=TradeTalk App

# Agent policy guardrails (in-process, defense-in-depth).
# These are NOT equivalent to OS/container sandboxing (e.g. OpenShell).
# When NemoClaw exits alpha, migrate to real out-of-process enforcement.
GUARDRAILS_ENABLE=1
GUARDRAILS_ALLOWED_HOSTS=
GUARDRAILS_STRICT_STARTUP=0

# Optional: OpenRouter embeddings for Supabase pgvector path.
OPENROUTER_EMBEDDING_MODEL=

# Vector memory backend selection.
# chroma = local file (ephemeral on Render free tier — data lost on restart).
# supabase = durable pgvector (recommended for production / Render).
VECTOR_BACKEND=supabase
CHROMA_PATH=./chroma_db

# Required when VECTOR_BACKEND=supabase. Run backend/supabase_pgvector_bootstrap.sql
# in Supabase SQL editor once before first deploy.
SUPABASE_URL=https://bvhdrwyxzjcoyqzmtean.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: batch ETL Parquet upload to a Hugging Face Dataset (see docs/BATCH_ETL.md).
# Same vars are used elsewhere for data-lake Hub reads (HF_DATASET_ID, HF_TOKEN).
# HF_DATASET_ID=
# HF_TOKEN=

# Retrieval defaults (resource-safe for local machines)
RAG_TOP_K=5
RAG_TOP_K_MAX=12

# LLM request safety knobs
LLM_MAX_CONCURRENCY=2
LLM_MAX_TOKENS=1500

# Chat movers: parallel Yahoo fast_info snapshot (session % vs prior close), then TTL cache.
# MIL_LIVE_MOVERS_TTL_SEC=120
# MIL_LIVE_MOVERS_WORKERS=16

# Optional: protect POST /knowledge/pipeline-run and POST /knowledge/sp500-ingest.
# When set, callers must send Authorization: Bearer <secret> or X-Cron-Secret: <secret>.
# Use the same value in GitHub Actions secret PIPELINE_CRON_SECRET. See docs/CRON.md.
PIPELINE_CRON_SECRET=

# Data lake incremental jobs (Parquet append + event slices). Set 0 on small Render instances.
DATA_LAKE_DAILY_INCREMENTAL=1

# Video Academy: Veo MP4 generation (Gemini API). Scene scripts use OpenRouter; Veo requires Google.
# Use GEMINI_API_KEY from AI Studio. Veo may need billing / model access — not replaceable via OpenRouter.
GEMINI_API_KEY=
GOOGLE_API_KEY=
# Default in code: veo-3.1-lite-generate-preview (Veo 3.1 Lite). Alternatives: veo-3.1-generate-preview, veo-3.1-fast-generate-preview
VIDEO_VEO_MODEL=veo-3.1-lite-generate-preview
# Per-scene clip length for Veo (allowed: 4, 6, or 8 seconds). Default 4.
VIDEO_VEO_DURATION_SECONDS=4
# If Veo cannot render an MP4, generate a text slide via OpenRouter (Qwen). Set 0 to disable.
VIDEO_VEO_OPENROUTER_FALLBACK=1

# CORAL hub — structured notes/skills/attempts (SQLite) + multi-agent heartbeat
# CORAL_AGENT_REFLECTIONS=1   # 0 = disable four per-agent notes (data_ingest, technical, sentiment, gold_analysis)
# CORAL_HEARTBEAT_ENABLED=1
# CORAL_HEARTBEAT_IGNORE_MARKET_HOURS=0   # 1 = run outside US regular session (dev/tests)
# CORAL_HEARTBEAT_MINUTES=30   # APScheduler interval (min 5)
# CORAL_NOTE_TTL_SEC=604800
# CORAL_DREAMING_ENABLED=1
# CORAL_DREAMING_HOURS=24
# CORAL_DREAM_NOTE_TTL_SEC=1209600
