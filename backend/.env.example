# Required for live TradeTalk chat (streaming). Without it, chat returns a fixed notice — see backend/llm_client.py stream_chat_plain.
# Get a key at https://openrouter.ai — copy backend/.env.example to backend/.env and set the value.
OPENROUTER_API_KEY=
# Optional second OpenRouter account — both keys share traffic via round-robin (one key per request by default).
OPENROUTER_API_KEY_2=
# 0 (default) = strict round-robin only (no automatic switch to the other key on 429). 1 = also try the other key after 429 on the first key.
OPENROUTER_429_TRY_OTHER_KEYS=0
# On 429: seconds to sleep before retrying the same key, then before switching keys (only when OPENROUTER_429_TRY_OTHER_KEYS=1).
OPENROUTER_429_SAME_KEY_DELAY_SEC=2.5
OPENROUTER_429_KEY_FAILOVER_DELAY_SEC=1.0
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter model IDs use vendor slugs (see openrouter.ai/models).
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_MODEL_LIGHT=google/gemma-4-31b-it:free
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=TradeTalk App

# Agent policy guardrails (in-process, defense-in-depth).
# These are NOT equivalent to OS/container sandboxing (e.g. OpenShell).
# When NemoClaw exits alpha, migrate to real out-of-process enforcement.
GUARDRAILS_ENABLE=1
GUARDRAILS_ALLOWED_HOSTS=
GUARDRAILS_STRICT_STARTUP=0

# RSPL resource registry (Phase A). See docs/RESOURCE_REGISTRY.md.
# 1 (default) = consumers read prompts from the versioned registry when present.
# 0           = force callers to fall back to hardcoded AGENT_SYSTEM_PROMPTS.
RESOURCES_USE_REGISTRY=1
# 1 (default) = on startup, seed registry from backend/resources/prompts/*.yaml.
# 0           = registry remains whatever is on disk; no YAML import.
RESOURCES_AUTOSEED=1
# Optional override for the SQLite file path. Defaults to backend/resources.db.
# Paths can be absolute or relative to the repo root.
RESOURCES_DB_PATH=

# SEPL (Self-Evolution Protocol Layer, Phase B). See docs/SEPL.md.
# Master switch — OFF by default. When 0, no scheduled cycles run and every
# /sepl/* live endpoint returns HTTP 503.
SEPL_ENABLE=0
# When 1, scheduled SEPL cycles are allowed to commit registry updates. When 0
# (default), scheduled cycles run in DRY-RUN only and just log would-be commits.
# POST /sepl/run also requires the caller to pass ``commit=true`` regardless.
SEPL_AUTOCOMMIT=0
# When 1 (default), POST /sepl/run without explicit commit=true stays dry-run.
# Flip to 0 only if you want live /sepl/run requests to default to live mode —
# not recommended.
SEPL_DRY_RUN=1
# Hours between scheduled cycles (integer, default 24).
SEPL_INTERVAL_HOURS=24
# Minimum reflection samples required before Select will consider a prompt.
SEPL_MIN_SAMPLES=10
# Margin (fraction 0..1) a candidate must beat the active prompt by on the
# eval fixture set before Commit will promote. Default 0.05 = 5 percentage
# points.
SEPL_MIN_MARGIN=0.05
# Hard cap on committed updates per prompt per 24h.
SEPL_MAX_PER_DAY=1
# Prompts with recent effectiveness above this ceiling are considered healthy
# and never Selected (fraction 0..1, default 0.6).
SEPL_EFFECTIVENESS_CEILING=0.6
# Max number of reflection lessons sent into the Improve operator's context
# (cost cap, default 6).
SEPL_CONTEXT_REFLECTIONS=6
# Auto-rollback (kill switch, PR 6): how much worse post-commit effectiveness
# must be, vs pre-commit, before we revert the change (fraction, default 0.10).
SEPL_ROLLBACK_MARGIN=0.10
# Minimum post-commit reflections required before the kill switch will act.
SEPL_ROLLBACK_MIN_SAMPLES=5
# Look-back window for recent SEPL commits the kill switch considers (hours).
SEPL_ROLLBACK_WINDOW_HOURS=168

# ───────────────────────────────────────────────────────────────────────────────
# SEPL Tool evolution (Phase C1 + C2). See docs/TOOL_EVOLUTION.md.
# SEPL-for-TOOLs evolves the NUMERIC CONFIG of registered tier-0/1 tools
# (NOT source code). Improve is a bounded random walk within the YAML-declared
# parameter_ranges — NO LLM is invoked. Evaluate is an offline shadow-mode
# scorer against held-out fixtures in backend/resources/sepl_eval_fixtures_tools/.
# Master switch — OFF by default. When 0, no tool cycles run.
SEPL_TOOL_ENABLE=0
# Scheduler cadence (integer hours, default 24). Only consulted when enabled.
SEPL_TOOL_INTERVAL_HOURS=24
# When 1 (default), cycles stop before Commit and just log would-be updates.
SEPL_TOOL_DRY_RUN=1
# Margin a candidate config must beat the active config by on the fixture set.
SEPL_TOOL_MIN_MARGIN=0.05
# Global cap on committed updates per tool per 24h (hard stop).
SEPL_TOOL_MAX_PER_DAY=2
# Tier-aware sub-caps — the effective limit is min(global, tier cap).
# Tier 0 (pure internal): default 2/day. Tier 1 (external read): default 1/day.
# Tier 2+ default to 0 — SEPL never commits tools that have external writes.
# SEPL_TOOL_MAX_PER_DAY_TIER_0=2
# SEPL_TOOL_MAX_PER_DAY_TIER_1=1
# SEPL_TOOL_MAX_PER_DAY_TIER_2=0
# SEPL_TOOL_MAX_PER_DAY_TIER_3=0
# Improve operator bounds — max perturbation steps per key per call and total
# candidates proposed per cycle. Keep both small to bound drift.
SEPL_TOOL_MAX_PERTURB_STEPS=4
SEPL_TOOL_CANDIDATES_PER_CYCLE=4
# Optional deterministic RNG seed for Improve — useful for tests.
# SEPL_TOOL_SEED=
# Tool kill switch — fixture-based auto-rollback of regressed SEPL commits.
# When 0 (default) the switch only REPORTS; when 1, it calls registry.restore.
SEPL_TOOL_AUTOCOMMIT=0
# Prior config must beat the committed one by this fraction on the fixture set.
SEPL_TOOL_ROLLBACK_MARGIN=0.05
# Inspect only commits inside this look-back window.
SEPL_TOOL_ROLLBACK_WINDOW_HOURS=168

# Optional: OpenRouter embeddings for Supabase pgvector path.
OPENROUTER_EMBEDDING_MODEL=

# Vector memory backend selection.
# chroma = local file (ephemeral on Render free tier — data lost on restart).
# supabase = durable pgvector (recommended for production / Render).
VECTOR_BACKEND=supabase
CHROMA_PATH=./chroma_db

# Required when VECTOR_BACKEND=supabase. Run backend/supabase_pgvector_bootstrap.sql
# in Supabase SQL editor once before first deploy.
SUPABASE_URL=https://bvhdrwyxzjcoyqzmtean.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: batch ETL Parquet upload to a Hugging Face Dataset (see docs/BATCH_ETL.md).
# Same vars are used elsewhere for data-lake Hub reads (HF_DATASET_ID, HF_TOKEN).
# HF_DATASET_ID=
# HF_TOKEN=

# Retrieval defaults (resource-safe for local machines)
RAG_TOP_K=5
RAG_TOP_K_MAX=12

# LLM request safety knobs
LLM_MAX_CONCURRENCY=2
LLM_MAX_TOKENS=1500

# Chat movers: parallel Yahoo fast_info snapshot (session % vs prior close), then TTL cache.
# MIL_LIVE_MOVERS_TTL_SEC=120
# MIL_LIVE_MOVERS_WORKERS=16

# Optional: protect POST /knowledge/pipeline-run and POST /knowledge/sp500-ingest.
# When set, callers must send Authorization: Bearer <secret> or X-Cron-Secret: <secret>.
# Use the same value in GitHub Actions secret PIPELINE_CRON_SECRET. See docs/CRON.md.
PIPELINE_CRON_SECRET=

# Data lake incremental jobs (Parquet append + event slices). Set 0 on small Render instances.
DATA_LAKE_DAILY_INCREMENTAL=1

# Video Academy: Veo MP4 generation (Gemini API). Scene scripts use OpenRouter; Veo requires Google.
# Use GEMINI_API_KEY from AI Studio. Veo may need billing / model access — not replaceable via OpenRouter.
GEMINI_API_KEY=
GOOGLE_API_KEY=
# When OpenRouter fails (e.g. 429), chat and agents can fall back to Gemini. Set 0 to disable.
# Only consulted when GEMINI_PRIMARY=0 (see below).
GEMINI_LLM_FALLBACK=1
# ───────────────────────────────────────────────────────────────────────────────
# GEMINI_PRIMARY — master switch for "use Gemini everywhere, burn Gemini credits"
#
# When 1 (and GEMINI_API_KEY is set):
#   • Streaming chat       → Gemini first, OpenRouter skipped entirely
#   • All agent JSON calls → Gemini first (bull/bear/moderator/swarm_*/strategy_parser/…)
#   • RAG narrative polish → Gemini
#   • Video text fallback  → Gemini (Veo itself is always Google-native)
#   • On Gemini failure    → deterministic FALLBACK_TEMPLATES (NOT OpenRouter)
# This is the mode to use when you have Gemini credits you want to consume.
# Set back to 0 to restore OpenRouter-primary + Gemini-fallback behavior.
GEMINI_PRIMARY=0
# When 1 (default): first OpenRouter 429 skips sleeps/retries and switches to Gemini immediately (less perceived lag).
GEMINI_INSTANT_OPENROUTER_FAILOVER=1
# ── Gemini model selection ────────────────────────────────────────────────────
# Heavy-reasoning paths (bull/bear/moderator/strategy_parser/gold_advisor/sepl_improver
# /backtest_explainer and any unmapped role). Default: Gemini 3.1 Pro Preview.
GEMINI_MODEL=gemini-3.1-pro-preview
# Lightweight paths (swarm_analyst/swarm_synthesizer/swarm_reflection_writer/
# rag_narrative_polish/video_scene_director/video_veo_text_fallback/
# decision_terminal_roadmap). Default: Gemini 3.1 Flash Lite Preview — cheaper
# and faster, same 3.1 family as the heavy model. Stable alternatives if you
# prefer: gemini-flash-latest, gemini-2.5-flash.
GEMINI_MODEL_LIGHT=gemini-3.1-flash-lite-preview
# Legacy alias for GEMINI_MODEL. Kept for backward compat; unset it to rely on GEMINI_MODEL above.
GEMINI_FALLBACK_MODEL=gemini-3.1-pro-preview
# Default in code: veo-3.1-lite-generate-preview (Veo 3.1 Lite). Alternatives: veo-3.1-generate-preview, veo-3.1-fast-generate-preview
VIDEO_VEO_MODEL=veo-3.1-lite-generate-preview
# Per-scene clip length for Veo (allowed: 4, 6, or 8 seconds). Default 4.
VIDEO_VEO_DURATION_SECONDS=4
# If Veo cannot render an MP4, generate a text slide via OpenRouter (Qwen). Set 0 to disable.
VIDEO_VEO_OPENROUTER_FALLBACK=1

# CORAL hub — structured notes/skills/attempts (SQLite) + multi-agent heartbeat
# CORAL_AGENT_REFLECTIONS=1   # 0 = disable four per-agent notes (data_ingest, technical, sentiment, gold_analysis)
# CORAL_HEARTBEAT_ENABLED=1
# CORAL_HEARTBEAT_IGNORE_MARKET_HOURS=0   # 1 = run outside US regular session (dev/tests)
# CORAL_HEARTBEAT_MINUTES=30   # APScheduler interval (min 5)
# CORAL_NOTE_TTL_SEC=604800
# CORAL_DREAMING_ENABLED=1
# CORAL_DREAMING_HOURS=24
# CORAL_DREAM_NOTE_TTL_SEC=1209600
